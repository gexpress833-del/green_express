# En local : même origine que Next (rewrites vers Laravel) pour que le jeton CSRF soit lisible en JS.
NEXT_PUBLIC_API_URL=http://localhost:3000
# Cible du proxy (php artisan serve) — utilisé par next.config.js rewrites uniquement.
API_PROXY_TARGET=http://localhost:8000
# Optionnel : si vous changez SESSION_COOKIE dans Laravel, aligner le middleware Next :
# NEXT_PUBLIC_SESSION_COOKIE_NAME=green-express-session

# Production (ex. front et API sur le même domaine ou selon votre hébergement) :
# NEXT_PUBLIC_API_URL=https://votre-front.vercel.app
# API_PROXY_TARGET= (souvent inutile si l’API est une URL absolue séparée)
