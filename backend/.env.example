APP_NAME="Green Express"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de données (développement local : sqlite | production : mysql/pgsql)
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite (par défaut pour sqlite)

# Pour MySQL/PostgreSQL, décommentez et adaptez :
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=system_gexpress
# DB_USERNAME=root
# DB_PASSWORD=

# Session (Sanctum SPA : 10080 = 7 jours, 4320 = 3 jours)
SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
# Production (HTTPS) : SESSION_SECURE_COOKIE=true, SESSION_SAME_SITE=none si cross-domain

# Sanctum SPA : domaines du frontend qui envoient les cookies
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# CORS (origines autorisées, séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT (optionnel, si encore utilisé ailleurs) — supprimé lorsque l'on utilise Sanctum

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@greenexpress.local"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudinary Image Storage (obligatoire pour les photos menus/promotions)
# Sans ces clés, l'upload d'images renverra une erreur 503.
# Inscription gratuite: https://cloudinary.com (50 GB/mois)
# Obtenir clés: Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optionnel : construction manuelle de l'URL au lieu de CLOUD_NAME+KEY+SECRET
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Paiement & Webhooks (Shwary utilise x-shwary-signature ; on accepte SHWARY_WEBHOOK_SECRET ou PAYMENT_WEBHOOK_SECRET)
PAYMENT_WEBHOOK_SECRET=change-me-in-production

# Shwary Mobile Money (RDC, Kenya, Ouganda)
# Documentation production : backend/docs/SHWARY_PRODUCTION.md
SHWARY_MERCHANT_ID=
SHWARY_MERCHANT_KEY=
# Ne pas inclure /api/v1 (le SDK l'ajoute)
SHWARY_BASE_URL=https://api.shwary.com
# Sandbox : true = environnement test Shwary, false = production (vrais paiements)
SHWARY_SANDBOX=true
# Mock : true = simuler les paiements sans appeler l'API (dev local). En production mettre false.
SHWARY_MOCK=true
# --- PRODUCTION : décommenter et adapter ---
# SHWARY_SANDBOX=false
# SHWARY_MOCK=false
# URL HTTPS du webhook (obligatoire en production). Shwary appelle cette URL pour confirmer les paiements.
# SHWARY_CALLBACK_URL=https://votre-domaine.com/api/shwary/callback
# Secret pour vérifier x-shwary-signature (générer : php -r "echo bin2hex(random_bytes(32));")
# SHWARY_WEBHOOK_SECRET=  # ou PAYMENT_WEBHOOK_SECRET (même clé dans le dashboard Shwary)
# Taux de conversion (si les menus sont en USD) : 1 USD = X CDF/KES/UGX
SHWARY_RATE_USD_TO_CDF=2500
SHWARY_RATE_USD_TO_KES=130
SHWARY_RATE_USD_TO_UGX=3800
SHWARY_DEFAULT_ORDER_CURRENCY=USD

VITE_APP_NAME="${APP_NAME}"
