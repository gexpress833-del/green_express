APP_NAME="Green Express"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Local : SQLite (aucun serveur ; artisan / db:seed-stats sans MySQL) ---
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
#
# --- Local : MySQL (XAMPP, Laragon, Docker) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_gexpress
DB_USERNAME=root
DB_PASSWORD=

# Production (Render, PostgreSQL) : copie privée backend/.env.production (gitignored).
# Ne pas mettre DB_CONNECTION=mysql avec une base Postgres → « could not find driver » (pdo_mysql).
# Render fournit souvent DATABASE_URL : laisser DB_CONNECTION vide ou pgsql + DB_URL / DATABASE_URL.
# DB_SSLMODE=require depuis l’extérieur ; DB_PGSQL_PORT si port custom.
#
# Exemple :
# DB_CONNECTION=pgsql
# DB_URL=postgresql://user:pass@dpg-xxxx.oregon-postgres.render.com:5432/dbname

SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

BROADCAST_CONNECTION=log

# ---------------------------------------------------------------------------
# WebSocket — diffusion temps réel (commandes, livraisons, abonnements, paiements)
# ---------------------------------------------------------------------------
# Mettez BROADCAST_CONNECTION=pusher (recommandé en production, zéro infra)
# ou BROADCAST_CONNECTION=reverb (auto-hébergé, voir scripts/setup_realtime_env.ps1).
#
# Pusher cloud (https://dashboard.pusher.com) — Channels app gratuit jusqu'à 200k msg/jour.
# Récupérer App ID / Key / Secret / Cluster (eu, mt1, ap1, …) sur le dashboard.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
# Laisser PUSHER_HOST vide pour utiliser le cloud Pusher (recommandé).
# Le renseigner uniquement si vous proxifiez (ex. soketi auto-hébergé).
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# Reverb (auto-hébergé) — alternative open-source si vous ne voulez pas Pusher cloud.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@greenexpress.local"
MAIL_FROM_NAME="${APP_NAME}"

# Option A : une ligne (dashboard Cloudinary → API Keys → « Environment variable »)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B : trois variables
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

PAYMENT_WEBHOOK_SECRET=change-me-in-production

# FlexPay / FlexPaie (RDC) — DM_CHIC / production Infoset
# Marchand : https://marchand.flexpay.cd — merchant + jeton JWT transmis par FlexPaie (ne jamais committer).
# FLEXPAY_TOKEN = JWT seul, ou collé avec préfixe « Bearer » (les deux sont acceptés).
FLEXPAY_MERCHANT=
FLEXPAY_TOKEN=
# dev = beta-backend | prod = backend.flexpay.cd (paiement) + apicheck.flexpaie.com (vérification)
FLEXPAY_ENV=dev
FLEXPAY_TIMEOUT=30
# Mock : true = aucun appel HTTP (développement local)
FLEXPAY_MOCK=true
# FLEXPAY_CALLBACK_URL=https://votre-domaine.com/api/flexpay/callback
# FLEXPAY_WEBHOOK_SECRET=
# Optionnel — URLs officielles si FLEXPAY_ENV=prod (défauts dans config) :
# Paiement Mobile Money : https://backend.flexpay.cd/api/rest/v1/paymentService
# Vérification : https://apicheck.flexpaie.com/api/rest/v1/check/{orderNumber}
# Carte (Visa/Mastercard) : https://cardpayment.flexpay.cd/v1.1/pay — abonnements entreprise B2B (retours = FRONTEND_URL + chemin ci-dessous)
# FLEXPAY_PAYMENT_BASE_URL=https://backend.flexpay.cd/api/rest/v1
# FLEXPAY_CHECK_BASE_URL=https://apicheck.flexpaie.com/api/rest/v1
# FLEXPAY_CARD_PAYMENT_URL=https://cardpayment.flexpay.cd/v1.1/pay
# FLEXPAY_CARD_RETURN_PATH=entreprise/subscriptions
FLEXPAY_RATE_USD_TO_CDF=2800
FLEXPAY_MIN_AMOUNT_CDF=2900

VITE_APP_NAME="${APP_NAME}"
